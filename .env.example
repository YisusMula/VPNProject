# ============================================================
# WireGuard VPN Server – Environment Variables
# Copy to .env and fill in your values before running.
# ============================================================

# Public IP or FQDN of the VPN server (VPS or home router with port forwarding).
# Used in client configs as the endpoint to connect to.
WG_HOST=your.server.public.ip.or.domain

# UDP port the WireGuard server listens on.  Must be open in your firewall/security-group.
WG_PORT=51820

# Default DNS servers pushed to road-warrior clients.
# Using Cloudflare + Google as fallback; change to your home router if you prefer split-DNS.
WG_DEFAULT_DNS=1.1.1.1,8.8.8.8

# WireGuard VPN subnet (CIDR notation).
# All peers (server + clients) receive addresses from this range.
WG_DEFAULT_ADDRESS=10.8.0.x   # server keeps .1; clients get .2, .3, …

# Web-UI admin password for wg-easy (bcrypt hash recommended for production).
# Generate with: docker run ghcr.io/wg-easy/wg-easy wgpw 'YourPassword'
WG_EASY_PASSWORD=changeme

# ---- Site-A (main home network) --------------------------------
# LAN subnet behind Site-A gateway.  VPN will route this subnet to all peers.
SITE_A_LAN=192.168.1.0/24
# Static WireGuard address assigned to the Site-A gateway peer.
SITE_A_VPN_IP=10.8.0.2

# ---- Site-B (secondary / office network) -----------------------
# LAN subnet behind Site-B gateway.
SITE_B_LAN=192.168.2.0/24
# Static WireGuard address assigned to the Site-B gateway peer.
SITE_B_VPN_IP=10.8.0.3

# ---- Road-warrior range (travelling clients) -------------------
# First address allocated to road-warrior clients.
ROAD_WARRIOR_START_IP=10.8.0.10
